# ── Copy this file to .env and fill in your values ──────────────────────────
# NEVER commit .env to GitHub!

# Required — get free key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — CoinGecko Pro key (leave blank for free tier)
COINGECKO_API_KEY=

# Set automatically by Render/Railway — leave blank for local
PORT=8080
COINDCX_PREFERRED_MARGIN_ASSET=USDT
COINDCX_RECOMMENDED_LEVERAGE_CAP=3
